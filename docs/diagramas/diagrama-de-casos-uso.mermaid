%% ═══════════════════════════════════════════════════════════════
%%  ESTILOS — paleta FLORESCER
%% ═══════════════════════════════════════════════════════════════

    classDef ator     fill:#F4E7D8,stroke:#8B5A7A,color:#5A2E52,font-weight:bold
    classDef publico  fill:#F6D1C9,stroke:#D96B4D,color:#5A2E52
    classDef authcs   fill:#EFC0B2,stroke:#B07CC6,color:#5A2E52
    classDef lidercs  fill:#E8B28A,stroke:#D96B4D,color:#5A2E52
    classDef admincs  fill:#F0E0F0,stroke:#8B5A7A,color:#5A2E52
    classDef externo  fill:#DDD0E8,stroke:#5A2E52,color:#5A2E52

    class MARIA,LIDER,ADMIN ator
    class UC01,UC02,UC03,UC04,UC05,UC06,UC07 publico
    class UC08,UC09 authcs
    class UC10,UC11,UC12,UC13,UC14 lidercs
    class UC15,UC16,UC17,UC18 admincs
    class SUPA externo