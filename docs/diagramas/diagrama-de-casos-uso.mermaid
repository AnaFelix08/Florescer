---
title: Diagrama de Casos de Uso — FLORESCER
---
graph LR

%% ═══════════════════════════════════════════════════════════════
%%  ATORES
%% ═══════════════════════════════════════════════════════════════

    MARIA(["Usuária\nMaria"])
    LIDER(["Liderança\nde Coletivo"])
    ADMIN(["Administradora"])
    SUPA(["Supabase\nAuth / BD"])

%% ═══════════════════════════════════════════════════════════════
%%  SISTEMA — CASOS DE USO agrupados por módulo
%% ═══════════════════════════════════════════════════════════════

    subgraph SISTEMA ["FLORESCER — Sistema"]

        %% ── Acesso público ──────────────────────────────────────
        subgraph PUB ["Acesso público"]
            UC01(["UC01\nVisualizar lista\nde coletivos"])
            UC02(["UC02\nConsultar perfil\ndo coletivo"])
            UC03(["UC03\nNavegar no\nmapa interativo"])
            UC04(["UC04\nBuscar por nome\nou área de atuação"])
            UC05(["UC05\nConsultar contatos\nde emergência"])
            UC06(["UC06\nVisualizar calendário\nde eventos"])
            UC07(["UC07\nCompartilhar coletivo\npelo WhatsApp"])
        end

        %% ── Autenticação ────────────────────────────────────────
        subgraph AUTH ["Autenticação"]
            UC08(["UC08\nRealizarlogin\npor e-mail"])
            UC09(["UC09\nRecuperar\nsenha"])
        end

        %% ── Painel da liderança ─────────────────────────────────
        subgraph PAINEL ["Painel da Liderança"]
            UC10(["UC10\nCadastrar\ncoletivo"])
            UC11(["UC11\nAtualizar dados\ndo coletivo"])
            UC12(["UC12\nCadastrar\nevento"])
            UC13(["UC13\nEditar ou cancelar\nevento"])
            UC14(["UC14\nAtualizar foto\ne descrição"])
        end

        %% ── Painel administrativo ───────────────────────────────
        subgraph PADMIN ["Painel Administrativo"]
            UC15(["UC15\nAprovar cadastro\nde coletivo"])
            UC16(["UC16\nRejeitar cadastro\nde coletivo"])
            UC17(["UC17\nGerenciar contatos\nde emergência"])
            UC18(["UC18\nDesativar coletivo\ncadastrado"])
        end

    end

